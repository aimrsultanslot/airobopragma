---
const title = "Robopragma";
const description = "AI Automation & Workflow Systems";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <style>
      :root {
        --bg: #050505;
        --card: #111111;
        --text: #f5f5f5;
        --accent: #7CFF00;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: Arial, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .card {
        width: 90%;
        max-width: 700px;
        padding: 48px;
        border-radius: 24px;
        background: var(--card);
        border: 1px solid rgba(255,255,255,0.08);
        text-align: center;
      }

      h1 {
        font-size: 56px;
        margin-bottom: 16px;
      }

      p {
        opacity: 0.8;
        line-height: 1.7;
        margin-bottom: 32px;
      }

      .button {
        display: inline-block;
        padding: 14px 24px;
        border-radius: 12px;
        background: var(--accent);
        color: black;
        text-decoration: none;
        font-weight: bold;
      }
    </style>
  </head>

  <body>
    <main class="card">
      <h1>Robopragma</h1>

      <p>
        AI Automation, Workflow Systems, and Autonomous Agent Infrastructure.
      </p>

      <a href="#" class="button">
        Launch Automation
      </a>
    </main>
  </body>
</html>
