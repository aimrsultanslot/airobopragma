---
const title = "Airoboragma";
const description =
  "AI workflow automation, autonomous agents, and business automation systems.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="canonical" href="https://airoboragma.pages.dev/" />

    <script type="application/ld+json">
      {
        JSON.stringify({
          "@context": "https://schema.org",
          "@type": "WebSite",
          name: "Airoboragma",
          url: "https://airoboragma.pages.dev/",
          description:
            "AI workflow automation and autonomous agent systems."
        })
      }
    </script>

    <style>
      :root {
        --bg: #050505;
        --card: #111111;
        --text: #f5f5f5;
        --muted: #a1a1aa;
        --accent: #7cff00;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: Arial, sans-serif;
        line-height: 1.6;
      }

      .container {
        width: 90%;
        max-width: 1100px;
        margin: auto;
      }

      header {
        padding: 28px 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }

      .logo {
        font-size: 22px;
        font-weight: bold;
      }

      .hero {
        padding: 120px 0;
        text-align: center;
      }

      .hero h1 {
        font-size: 64px;
        line-height: 1.1;
        margin-bottom: 24px;
      }

      .hero p {
        max-width: 720px;
        margin: auto;
        color: var(--muted);
        font-size: 20px;
      }

      .button {
        display: inline-block;
        margin-top: 40px;
        padding: 16px 28px;
        border-radius: 14px;
        background: var(--accent);
        color: black;
        font-weight: bold;
        text-decoration: none;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin: 80px 0;
      }

      .card {
        background: var(--card);
        padding: 28px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.08);
      }

      .card h3 {
        margin-bottom: 14px;
      }

      .card p {
        color: var(--muted);
      }

      footer {
        padding: 60px 0;
        border-top: 1px solid rgba(255,255,255,0.08);
        text-align: center;
        color: var(--muted);
      }
    </style>
  </head>

  <body>
    <header>
      <div class="container">
        <div class="logo">Airoboragma</div>
      </div>
    </header>

    <main class="container">
      <section class="hero">
        <h1>
          AI Workflow Automation
          <br />
          & Autonomous Systems
        </h1>

        <p>
          Build scalable AI workflows, automate business operations,
          and deploy intelligent agent systems with modern automation stacks.
        </p>

        <a href="#" class="button">
          Explore Automation
        </a>
      </section>

      <section class="grid">
        <div class="card">
          <h3>AI Agents</h3>

          <p>
            Autonomous AI systems for task execution,
            orchestration, and multi-agent workflows.
          </p>
        </div>

        <div class="card">
          <h3>Workflow Automation</h3>

          <p>
            Automate repetitive business processes using
            modern AI workflow architectures.
          </p>
        </div>

        <div class="card">
          <h3>Business Systems</h3>

          <p>
            Scalable automation systems for startups,
            creators, and enterprise operations.
          </p>
        </div>
      </section>
    </main>

    <footer>
      © 2026 Airoboragma. AI Automation Platform.
    </footer>
  </body>
</html>
